#!/usr/bin/expect -f
set timeout -1
spawn ssh root@193.53.127.116 "curl -fsSL https://deb.nodesource.com/setup_20.x | bash - && (apt-get install -y nodejs || yum install -y nodejs)"
expect {
    "password:" {
        send "m3h9W0pI8D1Z5Wq\r"
        exp_continue
    }
    "yes/no" {
        send "yes\r"
        exp_continue
    }
    eof
}
