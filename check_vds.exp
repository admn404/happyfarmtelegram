#!/usr/bin/expect -f
set timeout -1
spawn ssh root@193.53.127.116 "pm2 logs farm --lines 20 --nostream && ufw allow 3000/tcp || iptables -A INPUT -p tcp --dport 3000 -j ACCEPT"
expect {
    "password:" {
        send "m3h9W0pI8D1Z5Wq\r"
        exp_continue
    }
    "yes/no" {
        send "yes\r"
        exp_continue
    }
    eof
}
